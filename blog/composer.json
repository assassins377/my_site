{
    "name": "anime/blog",
    "description": "Блог на PHP 8.2 + MySQL 8 + Bootstrap 5 с MVC архитектурой",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\Core\\": "src/Core/",
            "App\\Controllers\\": "src/Controllers/",
            "App\\Models\\": "src/Models/",
            "App\\Views\\": "src/Views/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('logs/error.log') || touch('logs/error.log');\""
        ],
        "post-update-cmd": [
            "@php -r \"file_exists('logs/error.log') || touch('logs/error.log');\""
        ]
    }
}
